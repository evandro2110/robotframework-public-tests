<!-- # --- Configurações de Estilo e Convenção ---

# --- Regras para Robocop Ignorar (Excludes) ---

# Ignora o erro W0302 (Keyword name should be in title case)
# Escolhemos ignorar para permitir flexibilidade em nomes de keywords técnicas
--exclude W0302

# Ignora linhas muito longas (útil para locators complexos de Mobile/Web)
--exclude line-too-long

# Ignora excesso de documentação obrigatória em cada keyword (evita poluição visual)
--exclude missing-doc-keyword

# --- Regras de Qualidade (Habilitadas) ---

# Gera um relatório resumido ao final da execução -->
--reports rules_by_id,return_status