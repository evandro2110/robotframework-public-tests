# --- Configurações de Estilo e Convenção ---

# Ignora regra de nome nas keywords
--exclude W0302

# Ignora a quantidade de chamadas numa kw
--exclude W0503

# Ignora waring quando a palavra 'todo' ou 'todos' é mencionada em pt-br e robocop interpreta como to-do
--exclude W0701

# Ao final da execução da análise estática reporta as regras violadas por id
--reports rules_by_id